/*
** Bonus1 — source reconstruite à partir du désassemblage Ghidra.
**
** Comportement du vrai binaire :
**   - main attend 2 arguments : argv[1] (un nombre) et argv[2] (des données).
**   - count = atoi(argv[1]).
**   - SI count < 10 :
**         memcpy(buffer, argv[2], count * 4);   // buffer = 40 octets
**         si (count == 0x574f4c46)  ->  execl("/bin/sh", "sh", 0);
**     SINON : retourne 1.
**
*/

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

int	main(int argc, char **argv)
{
	char	buffer[40];	/* local_3c : tampon de 40 octets             */
	int	count;		/* local_14 : situé 40 octets après buffer    */

	count = atoi(argv[1]);		/* argv[1] : taille demandée          */

	if (count < 10)			/* test SIGNÉ -> un négatif passe     */
	{
		/* count * 4 : un négatif bien choisi déborde et donne une
		** petite taille non signée -> overflow contrôlé de buffer.   */
		memcpy(buffer, argv[2], count * 4);

		/* count a pu être écrasé par le memcpy ci-dessus. */
		if (count == 0x574f4c46)	/* "FLOW" */
			execl("/bin/sh", "sh", 0);

		return (0);
	}
	return (1);
}
