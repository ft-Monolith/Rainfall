/*
** Structure allouée sur le heap : un identifiant + un pointeur vers un buffer.
** Dans le binaire : puVar[0] = id, puVar[1] = buffer (chaque malloc fait 8 octets).
*/
typedef struct s_data
{
	int		id;		/* puVar[0] : vaut 1 pour la 1re struct, 2 pour la 2e */
	char	*buffer;	/* puVar[1] : pointe un malloc(8) qui reçoit argv[i] */
}	t_data;

/*
** m() : affiche la globale `c` (le password) suivie de l'heure courante.
** Jamais appelée par main -> on détourne puts() vers elle via la GOT.
*/
