#include <stdio.h>
#include <string.h>
#include <unistd.h>

/* &DAT_080486a0 : chaîne de prompt affichée avant chaque lecture (" - "). */
#define PROMPT " - "

/*
** Lit un mot sur stdin et le recopie (au plus 20 octets) dans dest.
** strncpy sans garantie de '\0' final -> source de l'overflow.
*/
void	p(char *dest, char *prompt)
{
	char	buf[4104];	/* local_100c : grand tampon de lecture */
	char	*nl;

	puts(prompt);
	read(0, buf, 0x1000);		/* lit jusqu'à 4096 octets        */
	nl = strchr(buf, '\n');
	*nl = '\0';			/* coupe au premier '\n'          */
	strncpy(dest, buf, 0x14);	/* 20 octets, PAS de '\0' garanti */
}

/*
** Lit deux mots et construit "<mot1> <mot2>" dans param_1 (result[54] de main).
*/
void	pp(char *param_1)
{
	char	word1[20];	/* local_34 */
	char	word2[20];	/* local_20 --> les deux sont cote a cote dans la memoire*/

	p(word1, PROMPT);
	p(word2, PROMPT);

	strcpy(param_1, word1);		/* si word1 non terminé \0-> lit word2 aussi */

	/* (param_1 + strlen(param_1)) : ajoute un espace séparateur.
	** Le do-while du désassemblage est un strlen() inliné. */
	param_1[strlen(param_1)] = ' ';
	param_1[strlen(param_1)] = '\0';

	strcat(param_1, word2);		/* concatène le 2ème mot */
}

int	main(void)
{
	char	result[54];	/* local_3a */

	pp(result);
