	if ((retaddr & 0xb0000000) == 0xb0000000)
	{
		printf("(%p)\n", (void *)retaddr);
		_exit(1);
	}

	puts(buf);
	strdup(buf);	/* recopie le buffer sur le heap (zone autorisée) */
}

